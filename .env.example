PROD=false
PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hubsme
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Azure Storage
